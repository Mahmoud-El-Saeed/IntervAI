# API Key for AI services
GROQ_API_KEY=grok-api-key

# API Key for Tavily (web search)
TAVILY_API_KEY=tavily-api-key

# Embeddings model
EMBEDDING_PROVIDER="groq"
EMBEDDING_MODEL="gpt-4o-2024-08-06-embedding-001"
EMBEDDING_DIMENSION=1024

# Database configuration
DB_USER=username
DB_PASSWORD=password
DB_NAME="intervai_db"
DATABASE_URI="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}"